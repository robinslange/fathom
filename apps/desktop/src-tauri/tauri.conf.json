{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fathom",
  "version": "0.0.1",
  "identifier": "nz.omit.fathom",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Fathom",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "category": "Education",
    "shortDescription": "Read philosophy at your depth without losing the words",
    "longDescription": "Fathom paraphrases classical philosophy text into Simple, Standard, or Scholarly registers while preserving every term-of-art that carries the argument."
  }
}
