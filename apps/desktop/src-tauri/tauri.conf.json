{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fathom",
  "version": "0.0.1",
  "identifier": "nz.omit.fathom",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Fathom",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Read philosophy at your depth without losing the words",
    "longDescription": "Fathom paraphrases classical philosophy text into Simple, Standard, or Scholarly registers while preserving every term-of-art that carries the argument."
  }
}
